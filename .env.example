# openQCA — Umgebungsvariablen (Vorlage)
# Kopiere diese Datei nach apps/web/.env.local und trage echte Werte ein.
# OHNE diese Werte läuft die App vollständig als kostenloser, local-first Kern —
# Cloud/KI/Zahlungen sind dann sauber deaktiviert.

# ─── App ────────────────────────────────────────────────────────────────────
# Öffentliche Basis-URL (für Stripe-Redirects). Lokal: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase (P3: Konto, Datenbank, Projekt-Speicherung) ───────────────────
# Aus dem Supabase-Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=DEIN_SUPABASE_ANON_KEY
# Service-Role-Key: NUR serverseitig (Stripe-Webhook aktualisiert damit den Tarif). Geheim halten!
SUPABASE_SERVICE_ROLE_KEY=DEIN_SUPABASE_SERVICE_ROLE_KEY

# ─── Anthropic (P4: KI-Assistenten) ─────────────────────────────────────────
# API-Key von console.anthropic.com. Modelle: claude-haiku-4-5 (Standard, günstig)
# und claude-sonnet-5 (Methoden-Absatz/Interpretation). Kosten laufen über dieses Konto.
ANTHROPIC_API_KEY=sk-ant-DEIN_ANTHROPIC_KEY

# ─── Stripe (P5: Abos / Institutions-Lizenz) ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_DEIN_STRIPE_SECRET
STRIPE_WEBHOOK_SECRET=whsec_DEIN_WEBHOOK_SECRET
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_DEIN_STRIPE_PUBLISHABLE
# Preis-IDs aus dem Stripe-Dashboard (Produkte → Preise anlegen):
STRIPE_PRICE_MONTHLY=price_MONATLICH_ID
STRIPE_PRICE_INSTITUTION=price_INSTITUTION_ID
